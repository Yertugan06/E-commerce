    {
      "id": 18,
      "gridPos": { "h": 8, "w": 4, "x": 16, "y": 24 },
      "type": "timeseries",
      "title": "Process Memory",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes"
        }
      },
      "targets": [
        { "expr": "app_process_resident_memory_bytes", "legendFormat": "Memory", "refId": "A" }
      ]
    },
    {
      "id": 19,
      "gridPos": { "h": 8, "w": 4, "x": 20, "y": 24 },
      "type": "timeseries",
      "title": "Process CPU",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
