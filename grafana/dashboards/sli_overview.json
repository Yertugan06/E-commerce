{
  "title": "E-Commerce SLI Overview",
  "uid": "ecommerce-sli-overview",
  "tags": ["sli", "ecommerce"],
  "timezone": "browser",
  "refresh": "15s",
  "editable": true,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 1,
      "panels": [],
      "title": "API Health",
      "type": "row"
    },
    {
      "id": 2,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "type": "stat",
      "title": "API Availability",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "thresholds",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.999 },
              { "color": "green", "value": 0.9999 }
            ]
          },
          "min": 0,
          "max": 1
        }
      },
      "targets": [
        { "expr": "sli:api_availability:ratio_5m", "legendFormat": "Availability", "refId": "A" }
      ]
    },
    {
      "id": 3,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "type": "stat",
      "title": "5xx Error Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "thresholds",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.005 },
              { "color": "red", "value": 0.01 }
            ]
          },
          "min": 0,
          "max": 1
        }
      },
      "targets": [
        { "expr": "sli:5xx_error_rate:5m", "legendFormat": "Error Rate", "refId": "A" }
      ]
    },
    {
      "id": 4,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "type": "stat",
      "title": "Database Status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "thresholds",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Down", "color": "red" }, "1": { "text": "Up", "color": "green" } } }
          ]
        }
      },
      "targets": [
        { "expr": "db_available", "legendFormat": "DB", "refId": "A" }
      ]
    },
    {
      "id": 5,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "type": "stat",
      "title": "Active DB Connections",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "thresholds",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "db_connections_active", "legendFormat": "Connections", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 6,
      "panels": [],
      "title": "Latency (p95)",
      "type": "row"
    },
    {
      "id": 7,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "type": "timeseries",
      "title": "Read Latency p95",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "sli:read_latency_p95:5m", "legendFormat": "Read p95", "refId": "A" }
      ]
    },
    {
      "id": 8,
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "type": "timeseries",
      "title": "Write Latency p95",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 2.0 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "sli:write_latency_p95:5m", "legendFormat": "Write p95", "refId": "A" }
      ]
    },
    {
      "id": 9,
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "type": "timeseries",
      "title": "Auth Latency p95",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 1.0 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "sli:auth_latency_p95:5m", "legendFormat": "Auth p95", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 },
      "id": 10,
      "panels": [],
      "title": "Checkout & Request Volume",
      "type": "row"
    },
    {
      "id": 11,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "type": "timeseries",
      "title": "Request Volume by Status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps"
        }
      },
      "targets": [
        { "expr": "rate(http_requests_total[5m])", "legendFormat": "{{status_group}}", "refId": "A" }
      ]
    },
    {
      "id": 12,
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 15 },
      "type": "stat",
      "title": "Checkout Success Rate",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "thresholds",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.9 },
              { "color": "green", "value": 0.95 }
            ]
          },
          "min": 0,
          "max": 1
        }
      },
      "targets": [
        {
          "expr": "rate(checkout_total{status=\"success\"}[30m]) / rate(checkout_total[30m])",
          "legendFormat": "Success Rate",
          "refId": "A"
        }
      ]
    },
    {
      "id": 13,
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 15 },
      "type": "stat",
      "title": "Checkout Duration p95",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "thresholds",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1.0 },
              { "color": "red", "value": 2.0 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(checkout_duration_seconds_bucket[5m]))",
          "legendFormat": "Checkout p95",
          "refId": "A"
        }
      ]
    },
    {
      "id": 14,
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 19 },
      "type": "timeseries",
      "title": "Checkout Count by Status",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        { "expr": "rate(checkout_total[5m])", "legendFormat": "{{status}}", "refId": "A" }
      ]
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 },
      "id": 15,
      "panels": [],
      "title": "SLI Validation & System Resources",
      "type": "row"
    },
    {
      "id": 16,
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 24 },
