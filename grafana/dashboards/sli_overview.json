        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "cps"
        }
      },
      "targets": [
        { "expr": "rate(app_process_cpu_seconds_total[5m])", "legendFormat": "CPU", "refId": "A" }
