    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 20,
      "panels": [],
      "title": "Auto-Scaling",
      "type": "row"
    },
    {
      "id": 21,
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 33 },
      "type": "stat",
      "title": "Backend Replicas",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "thresholds",
        "graphMode": "area",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        { "expr": "autoscaler_replicas_current", "legendFormat": "Current", "refId": "A" }
      ]
    },
    {
      "id": 22,
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 33 },
      "type": "stat",
      "title": "Scale Events (24h)",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "colorMode": "none",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": { "calcs": ["lastNotNull"], "values": false },
        "textMode": "auto"
      },
      "targets": [
        { "expr": "autoscaler_scale_up_events_total", "legendFormat": "Up", "refId": "A" },
        { "expr": "autoscaler_scale_down_events_total", "legendFormat": "Down", "refId": "B" }
      ]
    },
    {
      "id": 23,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 33 },
      "type": "timeseries",
      "title": "Replicas Over Time",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "calcs": ["lastNotNull", "max", "min"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short"
        }
      },
      "targets": [
        { "expr": "autoscaler_replicas_current", "legendFormat": "Actual", "refId": "A" },
        { "expr": "autoscaler_replicas_desired", "legendFormat": "Desired", "refId": "B" }
      ]
    },
    {
      "id": 24,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 37 },
      "type": "timeseries",
      "title": "CPU Utilization vs Scaling Thresholds",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "options": {
        "legend": { "calcs": ["lastNotNull", "max"], "displayMode": "table", "placement": "right" },
        "tooltip": { "mode": "multi" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.5 },
              { "color": "red", "value": 0.7 }
            ]
          },
          "min": 0,
          "max": 1
        }
      },
      "targets": [
        { "expr": "rate(app_process_cpu_seconds_total[2m])", "legendFormat": "CPU", "refId": "A" },
        { "expr": "0.7", "legendFormat": "Scale-Up Threshold (70%)", "refId": "B" },
        { "expr": "0.3", "legendFormat": "Scale-Down Threshold (30%)", "refId": "C" }
      ]
    }
