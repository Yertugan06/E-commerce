# PostgreSQL
postgres_port_external = 5433
postgres_user          = "postgres"
postgres_password      = "postgres"
postgres_db            = "ecommerce"

# Backend
backend_secret_key                  = "change-me-to-a-random-secret-key"
backend_algorithm                   = "HS256"
backend_access_token_expire_minutes = 30
backend_replicas                    = 1

# Nginx (load balancer — replaces direct backend port exposure)
nginx_port_external = 8000

# Frontend
frontend_port_external = 5173
frontend_vite_api_url  = "http://localhost:8000"

# Prometheus
prometheus_port_external = 9090

# Grafana
grafana_port_external   = 3000
grafana_admin_password  = "admin"

# ── Registry overrides (for CI/CD deploys only) ────────────────────────────
# When these are set, Terraform pulls pre-built images from the registry
# instead of building locally. Overridden by deploy.auto.tfvars on deploy.
# backend_image_registry_prefix  = "ghcr.io/myorg/myrepo/"
# frontend_image_registry_prefix = "ghcr.io/myorg/myrepo/"
# backend_image_tag              = "latest"
# frontend_image_tag             = "latest"
# nginx_image_registry_prefix    = "ghcr.io/myorg/myrepo/"
